# Binance API Configuration
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true
BINANCE_BASE_URL=https://demo-api.binance.com
BINANCE_WS_URL=wss://demo-stream.binance.com:9443/ws

# Trading Configuration
TRADING_MODE=paper  # paper, live
INITIAL_CAPITAL=500
RISK_PER_TRADE=0.08  # 8% of portfolio per trade
STOP_LOSS_PERCENTAGE=0.003  # 0.3%
TAKE_PROFIT_PERCENTAGE=0.005  # 0.5%
DAILY_LOSS_LIMIT=0.15  # 15% of portfolio
MAX_CONCURRENT_TRADES=3

# Trading Pairs
TRADING_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT

# Pair Selection Strategy
# Set PAIR_SELECTION_MODE=dynamic to automatically select the most volatile USDT pairs on startup.
# When dynamic mode is active, TRADING_PAIRS is used only as a fallback if the API call fails.
PAIR_SELECTION_MODE=static          # static | dynamic
TOP_VOLATILITY_PAIRS=5              # Number of top-volatility pairs to trade (dynamic mode)
MIN_VOLUME_24H_USDT=10000000        # Minimum 24h USD volume filter (10M USDT default)
VOLATILITY_REFRESH_INTERVAL=3600000 # How often to refresh pair selection in ms (1 hour default)

# Technical Indicators
EMA_SHORT=9
EMA_LONG=21
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BOLLINGER_PERIOD=20
BOLLINGER_DEVIATION=2

# Database
DATABASE_PATH=./data/trading_bot.db

# Logging Configuration
LOG_LEVEL=info  # error, warn, info, debug
LOG_FILE=./logs/trading_bot.log
LOG_DIRECTORY=./logs
LOG_MAX_SIZE=20m  # Maximum size per log file (k, m, g)
LOG_MAX_FILES=14  # Number of log files to keep
LOG_JSON=false  # Use JSON format for logs
LOG_CONSOLE=true  # Log to console

# Monitoring Configuration
MONITORING_ENABLED=true  # Enable system monitoring
METRICS_INTERVAL=30000  # Metrics collection interval in ms
HEALTH_CHECK_INTERVAL=60000  # Health check interval in ms

# Alert Thresholds
CPU_ALERT_THRESHOLD=80  # CPU usage alert threshold (%)
MEMORY_ALERT_THRESHOLD=85  # Memory usage alert threshold (%)
ERROR_RATE_THRESHOLD=5  # Error rate alert threshold (errors/min)
API_LATENCY_THRESHOLD=5000  # API latency alert threshold (ms)

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_ENABLED=true

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_NOTIFICATIONS=false