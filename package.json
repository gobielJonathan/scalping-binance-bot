{
  "name": "crypto-scalping-bot",
  "version": "1.0.0",
  "description": "High-frequency cryptocurrency scalping trading bot for Binance",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "paper-trade": "ts-node src/index.ts --mode=paper",
    "backtest": "ts-node scripts/backtest.ts",
    "backtest:basic": "ts-node scripts/backtest.ts basic",
    "backtest:advanced": "ts-node scripts/backtest.ts advanced",
    "backtest:optimize": "ts-node scripts/backtest.ts optimize",
    "backtest:all": "ts-node scripts/backtest.ts all",
    "test:backtest": "ts-node scripts/test-backtest.ts",
    "validate:paper": "ts-node scripts/validate-paper-trading.ts",
    "validate:paper:test": "ts-node scripts/validate-paper-trading.ts test",
    "validate:paper:benchmark": "ts-node scripts/validate-paper-trading.ts benchmark",
    "validate:paper:compare": "ts-node scripts/validate-paper-trading.ts compare",
    "validate:paper:continuous": "ts-node scripts/validate-paper-trading.ts continuous",
    "pm2:start": "pm2 start dist/index.js --name crypto-scalping-bot",
    "pm2:start:dev": "pm2 start src/index.ts --name crypto-scalping-bot --interpreter ts-node",
    "pm2:stop": "pm2 stop crypto-scalping-bot",
    "pm2:restart": "pm2 restart crypto-scalping-bot",
    "pm2:reload": "pm2 reload crypto-scalping-bot",
    "pm2:delete": "pm2 delete crypto-scalping-bot",
    "pm2:logs": "pm2 logs crypto-scalping-bot",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit",
    "deploy": "pnpm build && pnpm pm2:restart"
  },
  "keywords": [
    "cryptocurrency",
    "trading",
    "bot",
    "scalping",
    "binance",
    "algorithmic-trading"
  ],
  "author": "Crypto Scalping Bot",
  "license": "MIT",
  "dependencies": {
    "binance-api-node": "^0.13.8",
    "chart.js": "^4.4.0",
    "cors": "^2.8.6",
    "detect-port": "^2.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "simple-node-logger": "^21.8.12",
    "socket.io": "^4.7.4",
    "sqlite3": "^5.1.6",
    "uuid": "^13.0.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.7",
    "@types/lodash": "^4.14.201",
    "@types/node": "^20.9.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@types/winston": "^2.4.4",
    "@types/ws": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
