import { TechnicalIndicators } from '../utils/technicalIndicators';
import { TradingSignal, Candle, MarketData } from '../types';
import config from '../config';

/**
 * Enhanced Scalping strategy implementation
 * Focuses on quick trades with sophisticated signal generation
 */
export class ScalpingStrategy {
  private readonly emaShort: number;
  private readonly emaLong: number;
  private readonly rsiPeriod: number;
  private readonly rsiOverbought: number = 70;
  private readonly rsiOversold: number = 30;
  
  constructor() {
    this.emaShort = config.indicators.emaShort;
    this.emaLong = config.indicators.emaLong;
    this.rsiPeriod = config.indicators.rsiPeriod;
  }

  /**
   * Enhanced signal generation with sophisticated scoring and market regime detection
   */
  generateSignal(candles: Candle[], marketData: MarketData): TradingSignal {
    if (candles.length < Math.max(this.emaLong, this.rsiPeriod) + 1) {
      return this.createHoldSignal('Insufficient data', candles);
    }

    const prices = candles.map(c => c.close);
    const volumes = candles.map(c => c.volume);
    
    // Calculate all technical indicators
    const indicators = this.calculateAllIndicators(candles, prices, volumes);
    
    // Detect market regime
    const marketRegime = TechnicalIndicators.detectMarketRegime(prices, volumes);
    
    // Generate signal components with individual scoring
    const signalComponents = this.generateSignalComponents(indicators, marketRegime);
    
    // Calculate volume profile and market conditions
    const avgVolume = volumes.slice(-20).reduce((sum, vol) => sum + vol, 0) / 20;
    const currentVolume = volumes[volumes.length - 1];
    const volumeProfile = this.classifyVolumeProfile(currentVolume, avgVolume);
    
    // Calculate spread and liquidity metrics
    const spread = ((marketData.ask - marketData.bid) / marketData.price) * 100;
    const liquidityScore = this.calculateLiquidityScore(marketData, currentVolume, avgVolume);
    
    // Filter signals based on market conditions
    if (!this.passesMarketConditionFilter(spread, liquidityScore, marketRegime)) {
      return this.createHoldSignal('Poor market conditions', candles, indicators);
    }
    
    // Aggregate signal components
    const aggregatedSignal = this.aggregateSignalComponents(signalComponents, marketRegime);
    
    // Apply risk adjustment and signal calibration
    const riskAdjustedSignal = this.applyRiskAdjustment(aggregatedSignal, marketRegime, spread);
    
    // Create final signal with enhanced metadata
    if (riskAdjustedSignal.type !== 'HOLD') {
      const signalId = uuidv4();
      const metadata: SignalMetadata = {
        id: signalId,
        strategyId: this.strategyId,
        marketRegime,
        signalComponents,
        volumeProfile,
        spread,
        liquidityScore,
        timeDecayFactor: 1.0,
        lastUpdate: Date.now(),
        expiresAt: Date.now() + (5 * 60 * 1000) // 5 minutes
      };
      
      const enhancedSignal: TradingSignal = {
        ...riskAdjustedSignal,
        indicators,
        metadata,
        riskAdjustedStrength: riskAdjustedSignal.strength,
        expectedMovePercent: this.calculateExpectedMove(signalComponents, marketRegime),
        probabilityOfSuccess: this.calculateSuccessProbability(signalComponents, marketRegime),
        timeHorizon: this.calculateTimeHorizon(marketRegime),
        stopLoss: this.calculateStopLoss(marketData.price, riskAdjustedSignal.type, marketRegime),
        takeProfit: this.calculateTakeProfit(marketData.price, riskAdjustedSignal.type, marketRegime),
        maxRisk: this.calculateMaxRisk(riskAdjustedSignal.strength)
      };
      
      // Track signal for performance monitoring
      this.signalHistory.set(signalId, {
        signal: enhancedSignal,
        createdAt: Date.now()
      });
      
      return enhancedSignal;
    }

    return this.createHoldSignal('No strong signal detected', candles, indicators);
  }

  /**
   * Calculate all technical indicators
   */
  private calculateAllIndicators(candles: Candle[], prices: number[], volumes: number[]) {
    const emaShortArray = TechnicalIndicators.calculateEMA(prices, this.emaShort);
    const emaLongArray = TechnicalIndicators.calculateEMA(prices, this.emaLong);
    const rsiArray = TechnicalIndicators.calculateRSI(prices, this.rsiPeriod);
    const macd = TechnicalIndicators.calculateMACD(prices);
    const bollinger = TechnicalIndicators.calculateBollingerBands(prices);
    const volatility = TechnicalIndicators.calculateVolatility(prices);
    const stochastic = TechnicalIndicators.calculateStochastic(candles);
    const adx = TechnicalIndicators.calculateADX(candles);
    const atr = TechnicalIndicators.calculateATR(candles);
    const williamsR = TechnicalIndicators.calculateWilliamsR(candles);
    const cci = TechnicalIndicators.calculateCCI(candles);
    const obv = TechnicalIndicators.calculateOBV(candles);
    const vwap = TechnicalIndicators.calculateVWAP(candles);

    // Current values
    const currentPrice = prices[prices.length - 1];
    const prevPrice = prices[prices.length - 2] || currentPrice;

    return {
      ema9: emaShortArray.length > 0 ? emaShortArray[emaShortArray.length - 1] : currentPrice,
      ema21: emaLongArray.length > 0 ? emaLongArray[emaLongArray.length - 1] : currentPrice,
      rsi: rsiArray.length > 0 ? rsiArray[rsiArray.length - 1] : 50,
      macd: macd.macd.length > 0 ? macd.macd[macd.macd.length - 1] : 0,
      macdSignal: macd.signal.length > 0 ? macd.signal[macd.signal.length - 1] : 0,
      macdHistogram: macd.histogram.length > 0 ? macd.histogram[macd.histogram.length - 1] : 0,
      bollingerUpper: bollinger.upper.length > 0 ? bollinger.upper[bollinger.upper.length - 1] : currentPrice * 1.02,
      bollingerMiddle: bollinger.middle.length > 0 ? bollinger.middle[bollinger.middle.length - 1] : currentPrice,
      bollingerLower: bollinger.lower.length > 0 ? bollinger.lower[bollinger.lower.length - 1] : currentPrice * 0.98,
      volume: volumes[volumes.length - 1],
      priceChange: currentPrice - prevPrice,
      priceChangePercent: ((currentPrice - prevPrice) / prevPrice) * 100,
      volatility: volatility.length > 0 ? volatility[volatility.length - 1] : 0,
      stochastic: stochastic.k.length > 0 ? stochastic.k[stochastic.k.length - 1] : 50,
      adx: adx.length > 0 ? adx[adx.length - 1] : 25,
      atr: atr.length > 0 ? atr[atr.length - 1] : currentPrice * 0.01,
      obv: obv.length > 0 ? obv[obv.length - 1] : 0,
      vwap: vwap.length > 0 ? vwap[vwap.length - 1] : currentPrice,
      williams: williamsR.length > 0 ? williamsR[williamsR.length - 1] : -50,
      cci: cci.length > 0 ? cci[cci.length - 1] : 0
    };
  }

  /**
   * Generate individual signal components with scoring
   */
  private generateSignalComponents(indicators: any, marketRegime: MarketRegime): SignalComponent[] {
    const components: SignalComponent[] = [];

    // EMA Trend Component
    const emaTrendValue = indicators.ema9 > indicators.ema21 ? 1 : -1;
    const emaTrendStrength = Math.abs(indicators.ema9 - indicators.ema21) / indicators.ema21;
    components.push({
      name: 'EMA_TREND',
      value: emaTrendValue * Math.min(emaTrendStrength * 100, 100),
      weight: 0.20,
      contribution: 0,
      triggered: Math.abs(emaTrendValue * emaTrendStrength * 100) > 15
    });

    // RSI Component
    let rsiValue = 0;
    if (indicators.rsi < 30) rsiValue = (30 - indicators.rsi) * 2; // Oversold strength
    else if (indicators.rsi > 70) rsiValue = -(indicators.rsi - 70) * 2; // Overbought strength
    else rsiValue = (50 - Math.abs(indicators.rsi - 50)) / 2; // Neutral strength

    components.push({
      name: 'RSI_MOMENTUM',
      value: rsiValue,
      weight: 0.15,
      contribution: 0,
      triggered: indicators.rsi < 35 || indicators.rsi > 65
    });

    // MACD Component
    const macdValue = indicators.macd > indicators.macdSignal ? 
      Math.min((indicators.macd - indicators.macdSignal) * 1000, 100) :
      Math.max((indicators.macd - indicators.macdSignal) * 1000, -100);
    
    components.push({
      name: 'MACD_DIVERGENCE',
      value: macdValue,
      weight: 0.15,
      contribution: 0,
      triggered: Math.abs(macdValue) > 10
    });

    // Bollinger Band Component
    let bbValue = 0;
    const bbPosition = (indicators.ema9 - indicators.bollingerLower) / 
      (indicators.bollingerUpper - indicators.bollingerLower);
    
    if (bbPosition < 0.2) bbValue = (0.2 - bbPosition) * 200; // Near lower band
    else if (bbPosition > 0.8) bbValue = -(bbPosition - 0.8) * 200; // Near upper band
    
    components.push({
      name: 'BOLLINGER_POSITION',
      value: bbValue,
      weight: 0.12,
      contribution: 0,
      triggered: bbPosition < 0.25 || bbPosition > 0.75
    });

    // Stochastic Component
    let stochValue = 0;
    if (indicators.stochastic < 20) stochValue = (20 - indicators.stochastic) * 3;
    else if (indicators.stochastic > 80) stochValue = -(indicators.stochastic - 80) * 3;
    
    components.push({
      name: 'STOCHASTIC',
      value: stochValue,
      weight: 0.10,
      contribution: 0,
      triggered: indicators.stochastic < 25 || indicators.stochastic > 75
    });

    // ADX Trend Strength Component
    const adxValue = indicators.adx > 25 ? (indicators.adx - 25) / 2 : 0;
    components.push({
      name: 'TREND_STRENGTH',
      value: adxValue,
      weight: 0.08,
      contribution: 0,
      triggered: indicators.adx > 30
    });

    // Volume Component
    const avgVolume = indicators.volume; // Already calculated in main function
    const volumeRatio = indicators.volume / avgVolume;
    const volumeValue = volumeRatio > 1.5 ? Math.min((volumeRatio - 1) * 50, 50) : 0;
    
    components.push({
      name: 'VOLUME_CONFIRMATION',
      value: volumeValue,
      weight: 0.10,
      contribution: 0,
      triggered: volumeRatio > 1.3
    });

    // VWAP Component
    const vwapValue = indicators.ema9 > indicators.vwap ? 
      Math.min((indicators.ema9 - indicators.vwap) / indicators.vwap * 100, 50) :
      Math.max((indicators.ema9 - indicators.vwap) / indicators.vwap * 100, -50);
    
    components.push({
      name: 'VWAP_POSITION',
      value: vwapValue,
      weight: 0.10,
      contribution: 0,
      triggered: Math.abs(vwapValue) > 5
    });

    return components;
  }

  /**
   * Classify volume profile
   */
  private classifyVolumeProfile(currentVolume: number, avgVolume: number): 'high' | 'normal' | 'low' {
    const ratio = currentVolume / avgVolume;
    if (ratio > 1.5) return 'high';
    if (ratio < 0.7) return 'low';
    return 'normal';
  }

  /**
   * Calculate liquidity score
   */
  private calculateLiquidityScore(marketData: MarketData, currentVolume: number, avgVolume: number): number {
    const spreadScore = Math.max(0, 100 - (((marketData.ask - marketData.bid) / marketData.price) * 10000));
    const volumeScore = Math.min(100, (currentVolume / avgVolume) * 50);
    const volume24hScore = Math.min(100, (marketData.volume24h / 1000000) * 10); // Normalize to millions
    
    return (spreadScore * 0.4 + volumeScore * 0.4 + volume24hScore * 0.2);
  }

  /**
   * Check if market conditions are suitable for trading
   */
  private passesMarketConditionFilter(spread: number, liquidityScore: number, marketRegime: MarketRegime): boolean {
    const maxSpread = 0.1; // 0.1%
    const minLiquidity = 40;
    const minRegimeConfidence = 30;
    
    return spread < maxSpread && 
           liquidityScore > minLiquidity && 
           marketRegime.confidence > minRegimeConfidence;
  }

  /**
   * Aggregate signal components into final signal
   */
  private aggregateSignalComponents(components: SignalComponent[], marketRegime: MarketRegime): TradingSignal {
    // Calculate contributions
    let totalBuyScore = 0;
    let totalSellScore = 0;
    let totalWeight = 0;
    let triggeredComponents = 0;

    const reasons: string[] = [];

    components.forEach(component => {
      component.contribution = component.value * component.weight;
      totalWeight += component.weight;
      
      if (component.triggered) {
        triggeredComponents++;
        if (component.value > 0) {
          totalBuyScore += component.contribution;
          if (component.contribution > 5) {
            reasons.push(`${component.name}(+${component.contribution.toFixed(1)})`);
          }
        } else {
          totalSellScore += Math.abs(component.contribution);
          if (Math.abs(component.contribution) > 5) {
            reasons.push(`${component.name}(${component.contribution.toFixed(1)})`);
          }
        }
      }
    });

    // Require minimum number of triggered components
    const minTriggeredComponents = 3;
    if (triggeredComponents < minTriggeredComponents) {
      return {
        type: 'HOLD',
        strength: 0,
        confidence: 0,
        reason: `Insufficient signal components (${triggeredComponents}/${minTriggeredComponents})`,
        timestamp: Date.now(),
        indicators: {}
      };
    }

    // Calculate strength and confidence
    const netScore = totalBuyScore - totalSellScore;
    const strength = Math.min(Math.abs(netScore), 100);
    
    // Base confidence on triggered components and market regime
    const componentConfidence = (triggeredComponents / components.length) * 100;
    const regimeBonus = marketRegime.confidence * 0.3;
    const confidence = Math.min(componentConfidence + regimeBonus, 100);

    // Determine signal type
    const minSignalStrength = 40;
    const minConfidence = 50;
    
    let signalType: 'BUY' | 'SELL' | 'HOLD' = 'HOLD';
    
    if (strength >= minSignalStrength && confidence >= minConfidence) {
      signalType = netScore > 0 ? 'BUY' : 'SELL';
    }

    return {
      type: signalType,
      strength: Math.round(strength),
      confidence: Math.round(confidence),
      reason: reasons.length > 0 ? reasons.join(', ') : 'Weak signal components',
      timestamp: Date.now(),
      indicators: {}
    };
  }

  /**
   * Apply risk adjustment based on market conditions
   */
  private applyRiskAdjustment(signal: TradingSignal, marketRegime: MarketRegime, spread: number): TradingSignal {
    if (signal.type === 'HOLD') return signal;

    let adjustmentFactor = 1.0;

    // Adjust for market regime
    switch (marketRegime.type) {
      case 'volatile':
        adjustmentFactor *= 0.7; // Reduce strength in volatile markets
        break;
      case 'sideways':
        adjustmentFactor *= 0.8; // Reduce strength in sideways markets
        break;
      case 'trending_up':
      case 'trending_down':
        adjustmentFactor *= 1.1; // Boost strength in trending markets
        break;
    }

    // Adjust for spread
    const spreadPenalty = Math.max(0, (spread - 0.05) * 10); // Penalty for spreads > 0.05%
    adjustmentFactor *= Math.max(0.5, 1 - spreadPenalty);

    // Adjust for regime confidence
    adjustmentFactor *= (marketRegime.confidence / 100);

    const adjustedStrength = Math.round(signal.strength * adjustmentFactor);
    const adjustedConfidence = Math.round(signal.confidence * adjustmentFactor);

    return {
      ...signal,
      strength: Math.max(0, adjustedStrength),
      confidence: Math.max(0, adjustedConfidence),
      type: adjustedStrength < 25 || adjustedConfidence < 40 ? 'HOLD' : signal.type
    };
  }

  /**
   * Calculate expected move percentage
   */
  private calculateExpectedMove(components: SignalComponent[], marketRegime: MarketRegime): number {
    const signalStrength = components.reduce((sum, comp) => 
      sum + Math.abs(comp.contribution), 0);
    
    let baseMove = (signalStrength / 100) * 0.5; // Base 0.5% for full strength signal
    
    // Adjust for market regime
    switch (marketRegime.type) {
      case 'volatile':
        baseMove *= 1.5;
        break;
      case 'trending_up':
      case 'trending_down':
        baseMove *= 1.2;
        break;
      case 'sideways':
        baseMove *= 0.7;
        break;
    }

    return Math.round(baseMove * 100) / 100;
  }

  /**
   * Calculate success probability
   */
  private calculateSuccessProbability(components: SignalComponent[], marketRegime: MarketRegime): number {
    const triggeredRatio = components.filter(c => c.triggered).length / components.length;
    const avgComponentStrength = components.reduce((sum, comp) => 
      sum + Math.abs(comp.value), 0) / components.length;
    
    let baseProbability = (triggeredRatio * 0.6 + (avgComponentStrength / 100) * 0.4) * 100;
    
    // Adjust for market regime confidence
    baseProbability *= (marketRegime.confidence / 100);
    
    // Historical performance adjustment (simplified)
    baseProbability *= 0.65; // Average historical success rate
    
    return Math.round(Math.min(baseProbability, 85));
  }

  /**
   * Calculate time horizon for signal
   */
  private calculateTimeHorizon(marketRegime: MarketRegime): number {
    switch (marketRegime.type) {
      case 'volatile':
        return 2; // 2 minutes for volatile markets
      case 'trending_up':
      case 'trending_down':
        return 8; // 8 minutes for trending markets
      case 'sideways':
        return 5; // 5 minutes for sideways markets
      default:
        return 5;
    }
  }

  /**
   * Calculate stop loss level
   */
  private calculateStopLoss(currentPrice: number, signalType: 'BUY' | 'SELL', marketRegime: MarketRegime): number {
    let stopLossPercent = 0.8; // Base 0.8%
    
    // Adjust for market regime
    switch (marketRegime.type) {
      case 'volatile':
        stopLossPercent = 1.5;
        break;
      case 'trending_up':
      case 'trending_down':
        stopLossPercent = 1.0;
        break;
      case 'sideways':
        stopLossPercent = 0.6;
        break;
    }

    const multiplier = signalType === 'BUY' ? (1 - stopLossPercent / 100) : (1 + stopLossPercent / 100);
    return currentPrice * multiplier;
  }

  /**
   * Calculate take profit level
   */
  private calculateTakeProfit(currentPrice: number, signalType: 'BUY' | 'SELL', marketRegime: MarketRegime): number {
    let takeProfitPercent = 1.2; // Base 1.2%
    
    // Adjust for market regime
    switch (marketRegime.type) {
      case 'volatile':
        takeProfitPercent = 2.0;
        break;
      case 'trending_up':
      case 'trending_down':
        takeProfitPercent = 1.8;
        break;
      case 'sideways':
        takeProfitPercent = 0.8;
        break;
    }

    const multiplier = signalType === 'BUY' ? (1 + takeProfitPercent / 100) : (1 - takeProfitPercent / 100);
    return currentPrice * multiplier;
  }

  /**
   * Calculate maximum risk per trade
   */
  private calculateMaxRisk(strength: number): number {
    const baseRisk = config.trading.riskPerTrade || 0.02; // 2%
    const strengthMultiplier = strength / 100;
    return baseRisk * strengthMultiplier;
  }
  private checkBuyConditions(
    emaShort: number, emaLong: number, prevEmaShort: number, prevEmaLong: number,
    rsi: number, macd: number, macdSignal: number, price: number,
    bbLower: number, bbMiddle: number, isHighVolume: boolean, priceChangePercent: number
  ) {
    let strength = 0;
    let confidence = 0;
    const reasons: string[] = [];

    // EMA crossover and trend
    if (emaShort > emaLong && prevEmaShort <= prevEmaLong) {
      strength += 30;
      confidence += 25;
      reasons.push('EMA bullish crossover');
    } else if (emaShort > emaLong) {
      strength += 15;
      confidence += 10;
      reasons.push('EMA bullish trend');
    }

    // RSI oversold bounce
    if (rsi < this.rsiOversold && rsi > 25) {
      strength += 25;
      confidence += 20;
      reasons.push('RSI oversold bounce');
    } else if (rsi < 40 && rsi > this.rsiOversold) {
      strength += 15;
      confidence += 10;
      reasons.push('RSI recovery from oversold');
    }

    // MACD bullish signals
    if (macd > macdSignal && macd < 0) {
      strength += 20;
      confidence += 15;
      reasons.push('MACD bullish divergence');
    }

    // Bollinger Band support
    if (price <= bbLower * 1.002) {
      strength += 20;
      confidence += 15;
      reasons.push('Price near BB lower band');
    } else if (price < bbMiddle && price > bbLower) {
      strength += 10;
      confidence += 5;
      reasons.push('Price below BB middle');
    }

    // Volume confirmation
    if (isHighVolume) {
      strength += 10;
      confidence += 10;
      reasons.push('High volume confirmation');
    }

    // Recent price decline (good for scalping entries)
    if (priceChangePercent < -0.1 && priceChangePercent > -0.5) {
      strength += 15;
      confidence += 10;
      reasons.push('Minor price decline');
    }

    // Minimum threshold for scalping signals
    const signal = strength >= 50 && confidence >= 40;
    
    return {
      signal,
      strength: Math.min(strength, 100),
      confidence: Math.min(confidence, 100),
      reason: reasons.join(', ') || 'Weak buy signal'
    };
  }

  /**
   * Check sell conditions for scalping
   */
  private checkSellConditions(
    emaShort: number, emaLong: number, prevEmaShort: number, prevEmaLong: number,
    rsi: number, macd: number, macdSignal: number, price: number,
    bbUpper: number, bbMiddle: number, isHighVolume: boolean, priceChangePercent: number
  ) {
    let strength = 0;
    let confidence = 0;
    const reasons: string[] = [];

    // EMA crossover and trend
    if (emaShort < emaLong && prevEmaShort >= prevEmaLong) {
      strength += 30;
      confidence += 25;
      reasons.push('EMA bearish crossover');
    } else if (emaShort < emaLong) {
      strength += 15;
      confidence += 10;
      reasons.push('EMA bearish trend');
    }

    // RSI overbought reversal
    if (rsi > this.rsiOverbought && rsi < 75) {
      strength += 25;
      confidence += 20;
      reasons.push('RSI overbought reversal');
    } else if (rsi > 60 && rsi < this.rsiOverbought) {
      strength += 15;
      confidence += 10;
      reasons.push('RSI approaching overbought');
    }

    // MACD bearish signals
    if (macd < macdSignal && macd > 0) {
      strength += 20;
      confidence += 15;
      reasons.push('MACD bearish divergence');
    }

    // Bollinger Band resistance
    if (price >= bbUpper * 0.998) {
      strength += 20;
      confidence += 15;
      reasons.push('Price near BB upper band');
    } else if (price > bbMiddle && price < bbUpper) {
      strength += 10;
      confidence += 5;
      reasons.push('Price above BB middle');
    }

    // Volume confirmation
    if (isHighVolume) {
      strength += 10;
      confidence += 10;
      reasons.push('High volume confirmation');
    }

    // Recent price increase (good for scalping exits)
    if (priceChangePercent > 0.1 && priceChangePercent < 0.5) {
      strength += 15;
      confidence += 10;
      reasons.push('Minor price increase');
    }

    // Minimum threshold for scalping signals
    const signal = strength >= 50 && confidence >= 40;
    
    return {
      signal,
      strength: Math.min(strength, 100),
      confidence: Math.min(confidence, 100),
      reason: reasons.join(', ') || 'Weak sell signal'
    };
  }

  /**
   * Create a HOLD signal
   */
  private createHoldSignal(reason: string, candles: Candle[], indicators?: any): TradingSignal {
    const prices = candles.map(c => c.close);
    const currentPrice = prices[prices.length - 1] ?? 0;
    const prevPrice = prices[prices.length - 2] ?? currentPrice;
    
    return {
      type: 'HOLD',
      strength: 0,
      confidence: 0,
      reason,
      timestamp: Date.now(),
      indicators: indicators || {
        ema9: currentPrice,
        ema21: currentPrice,
        rsi: 50,
        macd: 0,
        macdSignal: 0,
        macdHistogram: 0,
        bollingerUpper: currentPrice * 1.02,
        bollingerMiddle: currentPrice,
        bollingerLower: currentPrice * 0.98,
        volume: candles[candles.length - 1]?.volume ?? 0,
        priceChange: currentPrice - prevPrice,
        priceChangePercent: prevPrice !== 0 ? ((currentPrice - prevPrice) / prevPrice) * 100 : 0
      }
    };
  }

  /**
   * Check if current market conditions are suitable for scalping
   */
  isScalpingConditionsGood(marketData: MarketData, volatility: number): boolean {
    // Good scalping conditions:
    // 1. Reasonable spread (< 0.1%)
    // 2. Good volatility (not too high, not too low)
    // 3. Decent volume
    
    const spreadPercent = ((marketData.ask - marketData.bid) / marketData.price) * 100;
    const isGoodSpread = spreadPercent < 0.1;
    const isGoodVolatility = volatility > 0.001 && volatility < 0.05; // 0.1% to 5%
    const hasVolume = marketData.volume24h > 0;
    
    return isGoodSpread && isGoodVolatility && hasVolume;
  }

  /**
   * Get optimal position size for scalping based on volatility
   */
  getOptimalPositionSize(accountBalance: number, volatility: number): number {
    const baseRiskPerTrade = config.trading.riskPerTrade;
    
    // Reduce position size in high volatility
    const volatilityAdjustment = Math.max(0.5, Math.min(1.0, 1 / (volatility * 50)));
    const adjustedRisk = baseRiskPerTrade * volatilityAdjustment;
    
    return accountBalance * adjustedRisk;
  }
}